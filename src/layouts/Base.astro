---
import "../styles/global.css";

const { title = "hmdsamci" } = Astro.props;
const pathname = Astro.url.pathname;

// highlight active nav link based on current path
const isActive = (path: string) =>
    pathname === path || pathname.startsWith(path + "/");
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
    </head>
    <body>
        <div class="container">
            <nav>
                <a href="/" class="site-title">{title}</a>
                <div class="nav-links">
                    <a href="/" class={isActive("/") ? "active" : ""}>Home</a>
                    <a
                        href="/archive"
                        class={isActive("/archive") ? "active" : ""}>Archive</a
                    >
                    <a href="/about" class={isActive("/about") ? "active" : ""}
                        >About</a
                    >
                </div>
            </nav>

            <main>
                <slot />
            </main>

            <footer>
                <a href="/">Home</a>
                <a href="/archive">Archive</a>
                <a href="/about">About</a>
                <a href="https://ko-fi.com/morber11">Ko-fi</a>
            </footer>
        </div>
        <img src="/raymoo.png" alt="" class="corner-img" />
    </body>
</html>

<script>
    import { getMediaItems, getOrPickMediaIndex } from "../lib/media";

    const items = getMediaItems();
    const index = getOrPickMediaIndex();
    const currentItem = items[index];

    const img = document.querySelector<HTMLImageElement>(".corner-img");

    // just to get rid of linting errors, this should never actually happen
    if (!img) throw new Error("corner-img not found");

    img.src = currentItem.image;

    if (currentItem.width) img.width = currentItem.width;
    if (currentItem.height) img.height = currentItem.height;

    let audio: HTMLAudioElement | undefined;
    img.addEventListener("click", () => {
        if (audio && !audio.paused) {
            audio.pause();
            audio.currentTime = 0;
        } else if (currentItem.audio) {
            const overrides = currentItem.optionalFunction?.();
            const effective = { ...currentItem, ...overrides };

            img.src = effective.image;
            audio = new Audio(effective.audio);
            audio.volume = effective.volume ?? 0.5;
            audio.play();
        }
    });
</script>
